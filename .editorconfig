root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab

[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2

[*.{ts,tsx,js,jsx,json,css,html}]
indent_size = 2

# Canonical JSON fixtures are byte-exact parity targets with no trailing
# newline — editors must not re-add one, or the TS/Python encoder parity
# test (src/lib/vga/canonical.parity.test.ts) will fail on a 1-byte drift.
[**/test-fixtures/vga/*.canonical.json]
insert_final_newline = false
