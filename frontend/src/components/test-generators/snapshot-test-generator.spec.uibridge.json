{
  "version": "1.0.0",
  "description": "Specs for the Snapshot Test Generator page — verifies the page structure, connection flow, and post-capture state",
  "groups": [
    {
      "id": "stg-page-structure",
      "name": "Page Structure",
      "description": "Verify the Snapshot Test Generator page renders its core layout elements",
      "category": "element-presence",
      "assertions": [
        {
          "id": "stg-title",
          "description": "Page title 'Snapshot Test Generator' is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "heading", "textContent": "Snapshot Test Generator" },
            "label": "Page title"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-beta-badge",
          "description": "Beta badge is visible",
          "category": "element-presence",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "textContent": "beta" },
            "label": "Beta badge"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-elements-tab",
          "description": "Elements tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Elements" },
            "label": "Elements tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-annotations-tab",
          "description": "Annotations tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Annotations" },
            "label": "Annotations tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-specs-tab",
          "description": "Test Specs tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Test Specs" },
            "label": "Test Specs tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-output-tab",
          "description": "Output tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Output" },
            "label": "Output tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "stg-capture-panel",
      "name": "Capture Panel",
      "description": "Verify the capture panel shows connection status and the capture button",
      "category": "element-presence",
      "assertions": [
        {
          "id": "stg-connection-status",
          "description": "Connection status indicator is visible (Connected or Disconnected)",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Connected|Disconnected" },
            "label": "Connection status"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-capture-button",
          "description": "Capture Snapshot button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Capture Snapshot" },
            "label": "Capture Snapshot button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-runner-url",
          "description": "Runner URL is displayed",
          "category": "element-presence",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "textContent": "localhost:9876" },
            "label": "Runner URL"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "stg-capture-button-state",
      "name": "Capture Button State",
      "description": "Verify the Capture Snapshot button is disabled when not connected",
      "category": "state-consistency",
      "assertions": [
        {
          "id": "stg-capture-disabled-when-disconnected",
          "description": "Capture Snapshot button is disabled when runner is not connected",
          "category": "state-consistency",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Capture Snapshot" },
            "label": "Capture Snapshot button"
          },
          "assertionType": "disabled",
          "source": "manual",
          "reviewed": true,
          "enabled": true,
          "notes": "This assertion is only valid when the runner is NOT connected. When connected, the button should be enabled.",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": { "textContent": "Disconnected" },
              "label": "Connection status indicator"
            },
            "text": "Disconnected"
          }
        }
      ],
      "source": "manual"
    },
    {
      "id": "stg-accessibility",
      "name": "Accessibility",
      "description": "Verify ARIA and keyboard accessibility for the Snapshot Test Generator",
      "category": "accessibility",
      "assertions": [
        {
          "id": "stg-tabs-keyboard-accessible",
          "description": "Tab buttons are keyboard accessible (have button role)",
          "category": "accessibility",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Elements" },
            "label": "Elements tab button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-capture-button-accessible",
          "description": "Capture button has accessible text",
          "category": "accessibility",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Capture Snapshot" },
            "label": "Capture Snapshot"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "stg-empty-state",
      "name": "Empty State",
      "description": "Verify the page shows appropriate empty state messages before a snapshot is captured",
      "category": "state-consistency",
      "assertions": [
        {
          "id": "stg-empty-elements-message",
          "description": "Elements tab shows 'No elements captured yet.' when no snapshot has been taken",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "textContent": "No elements captured yet" },
            "label": "Empty elements message"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "stg-empty-element-detail",
          "description": "Element detail panel shows 'Select an element to view details' when nothing is selected",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Select an element to view details" },
            "label": "Empty detail message"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    }
  ],
  "metadata": {
    "component": "SnapshotTestGenerator",
    "author": "Joshua Spinak",
    "createdAt": "2026-02-04T00:00:00.000Z",
    "pageUrl": "/automation-builder/snapshot-tests",
    "elementSource": "control",
    "tags": ["test-generator", "snapshot", "tier-1"]
  }
}
