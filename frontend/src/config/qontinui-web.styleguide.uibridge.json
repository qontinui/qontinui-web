{
  "version": "1.0.0",
  "name": "Qontinui Web Design System",
  "description": "Style guide for qontinui-web frontend. Validates components against the Qontinui design token system including brand colors, typography scale, spacing, and component patterns.",
  "tokens": {
    "colors": {
      "brand-primary": "#4A90D9",
      "brand-secondary": "#8B6BB5",
      "brand-success": "#4DB89D",
      "surface-canvas": "#111115",
      "surface-raised": "#1E1E22",
      "surface-hover": "#252529",
      "surface-active": "#2C2C32",
      "border-subtle": "#2A2A30",
      "border-default": "#3A3A42",
      "border-strong": "#4A4A54",
      "border-interactive": "#5A5A66",
      "text-primary": "#FFFFFF",
      "text-secondary": "#E4E4E7",
      "text-tertiary": "#A1A1AA",
      "text-muted": "#71717A",
      "text-disabled": "#52525B",
      "semantic-success": "#4DB89D",
      "semantic-warning": "#E5A853",
      "semantic-error": "#E5534B",
      "semantic-info": "#4A90D9"
    },
    "typography": {
      "fontFamilies": {
        "sans": "var(--font-geist-sans), system-ui, -apple-system, sans-serif",
        "mono": "var(--font-geist-mono), ui-monospace, monospace"
      },
      "fontSizes": {
        "xs": "0.75rem",
        "sm": "0.875rem",
        "base": "1rem",
        "lg": "1.125rem",
        "xl": "1.25rem",
        "2xl": "1.5rem",
        "3xl": "1.875rem",
        "4xl": "2.25rem"
      },
      "fontWeights": {
        "normal": "400",
        "medium": "500",
        "semibold": "600",
        "bold": "700"
      },
      "lineHeights": {
        "none": "1",
        "tight": "1.25",
        "snug": "1.375",
        "normal": "1.5",
        "relaxed": "1.625",
        "loose": "2"
      },
      "letterSpacings": {
        "tighter": "-0.05em",
        "tight": "-0.025em",
        "normal": "0em",
        "wide": "0.025em",
        "wider": "0.05em",
        "widest": "0.1em"
      }
    },
    "spacing": {
      "0": "0",
      "px": "1px",
      "0.5": "0.125rem",
      "1": "0.25rem",
      "1.5": "0.375rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "5": "1.25rem",
      "6": "1.5rem",
      "8": "2rem",
      "10": "2.5rem",
      "12": "3rem",
      "16": "4rem",
      "20": "5rem",
      "24": "6rem"
    },
    "borderRadius": {
      "none": "0",
      "sm": "0.125rem",
      "default": "0.25rem",
      "md": "0.375rem",
      "lg": "0.5rem",
      "xl": "0.75rem",
      "2xl": "1rem",
      "3xl": "1.5rem",
      "full": "9999px"
    },
    "shadows": {
      "none": "none",
      "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
      "md": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)",
      "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1)",
      "glow-primary": "0 0 12px rgba(74, 144, 217, 0.2)",
      "glow-secondary": "0 0 12px rgba(139, 107, 181, 0.2)",
      "glow-success": "0 0 12px rgba(77, 184, 157, 0.2)"
    },
    "breakpoints": {
      "sm": 640,
      "md": 768,
      "lg": 1024,
      "xl": 1280,
      "2xl": 1536
    }
  },
  "rules": [
    {
      "id": "btn-font-weight",
      "description": "All buttons must use font-weight: 500 (medium) to match the .btn-* classes which apply Tailwind's font-medium.",
      "selector": "button, [role=\"button\"], .btn-primary, .btn-secondary, .btn-success, .btn-ghost, .btn-destructive",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "font-weight",
          "tokenPath": "typography.fontWeights.medium"
        }
      ],
      "severity": "error"
    },
    {
      "id": "btn-border-radius",
      "description": "Buttons must use border-radius: 0.5rem (lg) to match rounded-lg from the button class definitions.",
      "selector": "button, [role=\"button\"], .btn-primary, .btn-secondary, .btn-success, .btn-ghost, .btn-destructive",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "border-radius",
          "tokenPath": "borderRadius.lg"
        }
      ],
      "severity": "error"
    },
    {
      "id": "btn-cursor-pointer",
      "description": "Enabled buttons must have cursor: pointer to indicate interactivity.",
      "selector": "button:not([disabled]), [role=\"button\"]:not([aria-disabled=\"true\"])",
      "constraints": [
        {
          "type": "exact",
          "property": "cursor",
          "value": "pointer"
        }
      ],
      "severity": "warning"
    },
    {
      "id": "h1-typography",
      "description": "H1 elements should use font-size 1.5rem (text-2xl) and font-weight 700 (bold), matching the .text-h1 class.",
      "selector": "h1, .text-h1",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "font-size",
          "tokenPath": "typography.fontSizes.2xl"
        },
        {
          "type": "tokenRef",
          "property": "font-weight",
          "tokenPath": "typography.fontWeights.bold"
        }
      ],
      "severity": "error"
    },
    {
      "id": "h2-typography",
      "description": "H2 elements should use font-size 1.25rem (text-xl) and font-weight 600 (semibold), matching the .text-h2 class.",
      "selector": "h2, .text-h2",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "font-size",
          "tokenPath": "typography.fontSizes.xl"
        },
        {
          "type": "tokenRef",
          "property": "font-weight",
          "tokenPath": "typography.fontWeights.semibold"
        }
      ],
      "severity": "error"
    },
    {
      "id": "h3-typography",
      "description": "H3 elements should use font-size 1.125rem (text-lg) and font-weight 600 (semibold), matching the .text-h3 class.",
      "selector": "h3, .text-h3",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "font-size",
          "tokenPath": "typography.fontSizes.lg"
        },
        {
          "type": "tokenRef",
          "property": "font-weight",
          "tokenPath": "typography.fontWeights.semibold"
        }
      ],
      "severity": "warning"
    },
    {
      "id": "body-text-size",
      "description": "Body text elements should use either 0.875rem (sm) or 1rem (base) font sizes from the typography scale.",
      "selector": ".text-body, .text-body-lg, p",
      "constraints": [
        {
          "type": "oneOf",
          "property": "font-size",
          "values": ["0.875rem", "14px", "1rem", "16px"]
        }
      ],
      "severity": "warning"
    },
    {
      "id": "text-color-compliance",
      "description": "Text elements should use approved text colors from the design token palette, not arbitrary colors.",
      "selector": "h1, h2, h3, h4, p, span, label, .text-body, .text-label",
      "constraints": [
        {
          "type": "oneOf",
          "property": "color",
          "values": [
            "#FFFFFF",
            "#ffffff",
            "rgb(255, 255, 255)",
            "#E4E4E7",
            "#e4e4e7",
            "rgb(228, 228, 231)",
            "#A1A1AA",
            "#a1a1aa",
            "rgb(161, 161, 170)",
            "#71717A",
            "#71717a",
            "rgb(113, 113, 122)",
            "#52525B",
            "#52525b",
            "rgb(82, 82, 91)",
            "#4A90D9",
            "#4a90d9",
            "rgb(74, 144, 217)",
            "#8B6BB5",
            "#8b6bb5",
            "rgb(139, 107, 181)",
            "#4DB89D",
            "#4db89d",
            "rgb(77, 184, 157)",
            "#E5A853",
            "#e5a853",
            "rgb(229, 168, 83)",
            "#E5534B",
            "#e5534b",
            "rgb(229, 83, 75)",
            "inherit",
            "currentColor"
          ]
        }
      ],
      "severity": "warning"
    },
    {
      "id": "card-border-radius",
      "description": "Cards should use border-radius: 0.5rem (lg) to match the .card class which applies rounded-lg.",
      "selector": ".card, .card-hover, .card-selected",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "border-radius",
          "tokenPath": "borderRadius.lg"
        }
      ],
      "severity": "error"
    },
    {
      "id": "card-background",
      "description": "Cards should use the surface-raised background color (#1E1E22) from design tokens.",
      "selector": ".card, .card-hover, .card-selected",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "background-color",
          "tokenPath": "colors.surface-raised"
        }
      ],
      "severity": "warning"
    },
    {
      "id": "input-border-radius",
      "description": "Form inputs should use border-radius: 0.375rem (md) to match the .input class which applies rounded-md.",
      "selector": "input[type=\"text\"], input[type=\"email\"], input[type=\"password\"], input[type=\"search\"], input[type=\"url\"], textarea, .input, .select",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "border-radius",
          "tokenPath": "borderRadius.md"
        }
      ],
      "severity": "error"
    },
    {
      "id": "input-background",
      "description": "Form inputs should use the surface-canvas background (#111115) to match the .input class definition.",
      "selector": "input[type=\"text\"], input[type=\"email\"], input[type=\"password\"], textarea, .input",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "background-color",
          "tokenPath": "colors.surface-canvas"
        }
      ],
      "severity": "warning"
    },
    {
      "id": "badge-font-size",
      "description": "Badges should use font-size: 0.75rem (xs / 12px) to match the .badge class which applies text-xs.",
      "selector": ".badge, .badge-muted, .badge-success, .badge-warning, .badge-danger, .badge-info, .badge-primary, .badge-secondary",
      "constraints": [
        {
          "type": "tokenRef",
          "property": "font-size",
          "tokenPath": "typography.fontSizes.xs"
        },
        {
          "type": "tokenRef",
          "property": "font-weight",
          "tokenPath": "typography.fontWeights.medium"
        }
      ],
      "severity": "error"
    },
    {
      "id": "interactive-cursor",
      "description": "Interactive elements (links, selects, clickable items) must show cursor: pointer.",
      "selector": "a[href], .select, .explorer-panel-item, .explorer-panel-thumbnail, .tab-item",
      "constraints": [
        {
          "type": "exact",
          "property": "cursor",
          "value": "pointer"
        }
      ],
      "severity": "warning"
    },
    {
      "id": "font-size-range",
      "description": "All font sizes should fall within the design system range of 12px to 36px (0.75rem to 2.25rem).",
      "selector": "*",
      "constraints": [
        {
          "type": "range",
          "property": "font-size",
          "min": 12,
          "max": 36,
          "unit": "px"
        }
      ],
      "severity": "info"
    }
  ]
}
