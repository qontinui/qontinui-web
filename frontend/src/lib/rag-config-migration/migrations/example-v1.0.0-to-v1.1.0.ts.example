/**
 * Example RAG Migration: v1.0.0 → v1.1.0
 *
 * This is a template for creating new RAG migrations.
 * Copy this file and rename it to vX.Y.Z-to-vA.B.C.ts
 *
 * Example changes this migration makes:
 * 1. Add semanticTags array to all elements
 * 2. Add confidence score to bounding boxes
 * 3. Update embedding config with new model version
 */

import type { RAGMigration, RAGConfig, RAGMigrationContext } from "../types";

export const migrationV10ToV11: RAGMigration = {
  fromVersion: "1.0.0",
  toVersion: "1.1.0",

  description: "Add semantic tags and confidence scores to elements",

  /**
   * Set to true if this migration requires re-embedding all elements
   *
   * Set to true when:
   * - Embedding model versions change
   * - Element structure changes (bounding boxes, OCR text)
   * - Fields that affect embeddings are modified
   *
   * Set to false when:
   * - Only UI/display fields are added
   * - Non-embedded metadata changes
   * - Reference IDs are updated
   */
  requiresReembedding: false,

  /**
   * Transform config from v1.0.0 to v1.1.0
   *
   * IMPORTANT: Always use structuredClone() to prevent mutations
   */
  migrate(config: RAGConfig, context: RAGMigrationContext): RAGConfig {
    // Clone to prevent mutations
    const migrated = structuredClone(config);

    // Add semantic tags to all elements
    migrated.elements = migrated.elements.map((element) => ({
      ...element,
      semanticTags: [], // New field in v1.1.0
    }));

    // Add confidence scores to bounding boxes
    migrated.elements = migrated.elements.map((element) => ({
      ...element,
      boundingBox: {
        ...element.boundingBox,
        confidence: 1.0, // New field in v1.1.0
      },
    }));

    // Update embedding config (example: new model version)
    migrated.embeddingConfig = {
      ...migrated.embeddingConfig,
      textModelVersion: "v2", // Updated in v1.1.0
    };

    // Always update version
    migrated.version = "1.1.0";

    // Optional: Add migration warning
    context.warnings.push(
      "Added semantic tags and confidence scores to all elements"
    );

    return migrated;
  },

  /**
   * Optional: Check if this migration needs to run
   *
   * Return false to skip migration if config already has the changes
   */
  isApplicable(config: RAGConfig): boolean {
    // Check if any element is missing semanticTags
    const needsMigration = config.elements.some(
      (el) => !(el as any).semanticTags
    );
    return needsMigration;
  },

  /**
   * Optional: Validate that migration was successful
   *
   * Return false to fail the migration if validation doesn't pass
   */
  validate(config: RAGConfig): boolean {
    // Ensure all elements have semanticTags
    const allHaveTags = config.elements.every(
      (el) => Array.isArray((el as any).semanticTags)
    );

    // Ensure all bounding boxes have confidence
    const allHaveConfidence = config.elements.every(
      (el) => typeof (el.boundingBox as any).confidence === "number"
    );

    return allHaveTags && allHaveConfidence;
  },
};

/**
 * Example usage in migrations/index.ts:
 *
 * import { migrationV10ToV11 } from './v1.0.0-to-v1.1.0';
 *
 * export const CURRENT_RAG_VERSION = "1.1.0";
 *
 * export const RAG_MIGRATIONS: RAGMigration[] = [
 *   migrationV10ToV11,
 * ];
 */

/**
 * Example type updates needed in types.ts:
 *
 * export interface RAGElement {
 *   // ... existing fields
 *   semanticTags?: string[]; // Added in v1.1.0
 * }
 *
 * export interface BoundingBox {
 *   x: number;
 *   y: number;
 *   width: number;
 *   height: number;
 *   confidence?: number; // Added in v1.1.0
 * }
 */
