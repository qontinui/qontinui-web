/**
 * EXAMPLE Migration: v2.0.0 → v2.1.0
 *
 * This is a template for future migrations.
 * To use: Rename to v2.0.0-to-v2.1.0.ts and add to migrations/index.ts
 *
 * Example changes:
 * - FIND actions: imageId (string) → imageIds (array)
 * - MOUSE_MOVE targets: "Last Find Result" (string) → {type: 'lastFindResult'} (object)
 * - CLICK actions: clickType → mouseButton, clickCount → numberOfClicks
 */

import type { Migration, MigrationContext } from '../migration-types';

export const migrationV2ToV21: Migration = {
  fromVersion: '2.0.0',
  toVersion: '2.1.0',
  description: 'Normalize action target configs and FIND imageIds',

  migrate(config: any, context: MigrationContext): any {
    const migrated = structuredClone(config);

    // Migrate each workflow
    for (const workflow of migrated.workflows || []) {
      for (const action of workflow.actions || []) {
        // Migrate FIND actions: imageId → imageIds
        if (action.type === 'FIND') {
          if (action.config?.target?.imageId && !action.config.target.imageIds) {
            action.config.target.imageIds = [action.config.target.imageId];
            delete action.config.target.imageId;
            context.warnings.push(
              `Workflow ${workflow.id}, Action ${action.id}: Migrated FIND imageId → imageIds`
            );
          }
        }

        // Migrate CLICK actions: rename fields
        if (action.type === 'CLICK') {
          let changed = false;

          // clickType → mouseButton
          if (action.config?.clickType && !action.config.mouseButton) {
            action.config.mouseButton = action.config.clickType.toUpperCase();
            delete action.config.clickType;
            changed = true;
          }

          // clickCount → numberOfClicks
          if (action.config?.clickCount && !action.config.numberOfClicks) {
            action.config.numberOfClicks = action.config.clickCount;
            delete action.config.clickCount;
            changed = true;
          }

          if (changed) {
            context.warnings.push(
              `Workflow ${workflow.id}, Action ${action.id}: Normalized CLICK config fields`
            );
          }
        }

        // Migrate MOUSE_MOVE: string targets → object targets
        if (action.type === 'MOUSE_MOVE') {
          if (typeof action.config?.target === 'string') {
            const oldTarget = action.config.target;
            let newTarget: any;

            if (oldTarget === 'Last Find Result') {
              newTarget = { type: 'lastFindResult' };
            } else if (oldTarget === 'Current Position') {
              newTarget = { type: 'currentPosition' };
            } else {
              // Unknown string target, keep as-is but warn
              context.warnings.push(
                `Workflow ${workflow.id}, Action ${action.id}: Unknown MOUSE_MOVE target "${oldTarget}"`
              );
              continue;
            }

            action.config.target = newTarget;
            context.warnings.push(
              `Workflow ${workflow.id}, Action ${action.id}: Normalized MOUSE_MOVE target from "${oldTarget}"`
            );
          }
        }
      }
    }

    // Update config version
    migrated.version = '2.1.0';

    return migrated;
  },

  isApplicable(config: any): boolean {
    // Check if any actions need migration
    for (const workflow of config.workflows || []) {
      for (const action of workflow.actions || []) {
        // Check FIND actions
        if (action.type === 'FIND' && action.config?.target?.imageId) {
          return true;
        }

        // Check CLICK actions
        if (action.type === 'CLICK') {
          if (action.config?.clickType || action.config?.clickCount) {
            return true;
          }
        }

        // Check MOUSE_MOVE actions
        if (action.type === 'MOUSE_MOVE' && typeof action.config?.target === 'string') {
          return true;
        }
      }
    }

    return false;
  },

  validate(config: any): boolean {
    // Validate that migration was successful
    for (const workflow of config.workflows || []) {
      for (const action of workflow.actions || []) {
        // Ensure FIND actions use imageIds (not imageId)
        if (action.type === 'FIND' && action.config?.target?.imageId) {
          return false;
        }

        // Ensure CLICK uses new field names
        if (action.type === 'CLICK') {
          if (action.config?.clickType || action.config?.clickCount) {
            return false;
          }
        }

        // Ensure MOUSE_MOVE targets are objects
        if (action.type === 'MOUSE_MOVE' && typeof action.config?.target === 'string') {
          return false;
        }
      }
    }

    return true;
  },
};
