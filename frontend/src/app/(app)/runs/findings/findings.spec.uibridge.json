      "assertions": [
        {
          "id": "findings-purpose-aggregate",
          "description": "Users can see all findings aggregated across task runs with severity and category breakdowns",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Findings"
            },
            "label": "Findings heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "findings-purpose-filter",
          "description": "Users can filter findings by severity, category, and status to focus on actionable issues",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Critical"
            },
            "label": "Critical severity count"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "findings-purpose-resolve",
          "description": "Users can resolve findings individually or trigger auto-fix workflows to remediate issues",
          "category": "semantic",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Fix All"
            },
            "label": "Fix All button"
          },
          "assertionType": "exists",
