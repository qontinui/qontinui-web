        {
          "id": "findings-state-high-filter-enabled",
          "description": "High severity filter control is enabled and interactive",
          "category": "state-consistency",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "High"
            },
            "label": "High severity filter button"
