          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "Critical"
            },
            "label": "Critical severity filter button"
          },
          "assertionType": "enabled",
          "source": "manual",
          "reviewed": true,
          "enabled": true
