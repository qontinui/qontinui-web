          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "placeholder": "Search runs..." },
            "label": "Search input"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
