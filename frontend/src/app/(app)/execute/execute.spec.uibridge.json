{
  "version": "1.0.0",
  "description": "Specs for the Execute page — batch workflow execution with drag-and-drop sequence building",
  "groups": [
    {
      "id": "exec-page-purpose",
      "name": "Page Purpose",
      "description": "The Execute page lets users queue multiple workflows into an ordered execution sequence, then run them all in batch. Users drag workflows from a searchable library into the sequence builder, reorder them, save named sequences for reuse, and configure stop-on-failure behavior.",
      "category": "semantic",
      "assertions": [
        {
          "id": "exec-purpose-library",
          "description": "Users can browse and search a library of all available workflows to add to their execution queue",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Workflow Library" },
            "label": "Workflow library panel"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "exec-purpose-sequence",
          "description": "Users can build an ordered execution sequence by dragging workflows from the library into the queue",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Sequence Builder" },
            "label": "Sequence builder panel"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "exec-purpose-run",
          "description": "Users can run the entire queued sequence of workflows with a single action",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Run" },
            "label": "Run sequence button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "exec-purpose-save",
          "description": "Users can save named sequences for reuse and load previously saved sequences",
          "category": "semantic",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Save" },
            "label": "Save sequence button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    }
  ],
