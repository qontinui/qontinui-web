    {
      "id": "ctx-page-purpose",
      "name": "Page Purpose",
      "description": "The Contexts page lets users create and manage reusable AI context documents that provide domain knowledge for workflow prompts. Each context has a name, description, markdown content, scope, and optional auto-include rules that automatically attach the context when matching keywords or action types are detected.",
      "category": "semantic",
      "assertions": [
        {
          "id": "ctx-purpose-manage",
          "description": "Users can create, edit, delete, and duplicate context documents from the sidebar list",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Contexts" },
            "label": "Contexts page heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "ctx-purpose-edit",
          "description": "Users can write markdown content for each context using a Monaco code editor",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Content" },
            "label": "Content editor section"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "ctx-purpose-autoinc",
          "description": "Users can configure auto-include rules with keywords, action types, and error patterns so contexts attach automatically to matching workflows",
