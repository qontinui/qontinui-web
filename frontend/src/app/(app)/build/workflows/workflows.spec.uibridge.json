{
  "version": "1.0.0",
  "description": "Comprehensive specs for the Workflow Builder page — the primary authoring environment for creating multi-phase AI automation workflows",
  "groups": [
    {
      "id": "wf-page-structure",
      "name": "Page Structure",
      "description": "Core layout elements of the Workflow Builder page: heading, sidebar, and main content area",
      "category": "element-presence",
      "assertions": [
        {
          "id": "wf-struct-heading",
          "description": "Page heading 'Workflows' is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "heading", "textContent": "Workflows" },
            "label": "Workflows page heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-struct-sidebar",
          "description": "Sidebar workflow list area is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "complementary" },
            "label": "Sidebar region"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-struct-main",
          "description": "Main content area is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "main" },
            "label": "Main content region"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "wf-sidebar-elements",
      "name": "Sidebar Elements",
      "description": "Sidebar controls for managing workflows: search input, new workflow button, and workflow list items",
      "category": "element-presence",
      "assertions": [
        {
          "id": "wf-sidebar-search",
          "description": "Search input for filtering workflows is present",
          "category": "element-presence",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "searchbox" },
            "label": "Workflow search input"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-sidebar-new-btn",
          "description": "New Workflow button is present in sidebar",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "New" },
            "label": "New Workflow button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "wf-sidebar-state",
      "name": "Sidebar Interactive State",
      "description": "Interactive state of sidebar controls: new button always enabled, search input starts empty",
      "category": "state-consistency",
      "assertions": [
        {
          "id": "wf-sidebar-new-btn-enabled",
          "description": "New Workflow button is always enabled",
          "category": "state-consistency",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "New" },
            "label": "New Workflow button"
          },
          "assertionType": "enabled",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-sidebar-search-empty",
          "description": "Search input is initially empty",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "role": "searchbox" },
            "label": "Workflow search input"
          },
          "assertionType": "hasValue",
          "expected": "",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "wf-ai-panel-presence",
      "name": "AI Generate Panel Presence",
      "description": "AI Generate panel elements visible when no workflow is selected (default landing state)",
      "category": "element-presence",
      "assertions": [
        {
          "id": "wf-ai-panel-heading",
          "description": "AI generation heading is visible",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Generate Workflow with AI" },
            "label": "AI generation heading"
          },
          "assertionType": "exists",
          "precondition": "No workflow is selected in the sidebar (default landing state)",
          "condition": {
            "type": "notExists",
            "target": {
              "type": "search",
              "criteria": { "role": "button", "textContent": "Run" }
            }
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-ai-panel-textarea",
          "description": "Prompt textarea for describing the desired workflow is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "textbox" },
            "label": "AI prompt textarea"
          },
          "assertionType": "exists",
          "precondition": "No workflow is selected — AI panel is showing",
          "condition": {
            "type": "notExists",
            "target": {
              "type": "search",
              "criteria": { "role": "button", "textContent": "Run" }
            }
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "wf-ai-panel-form",
      "name": "AI Generate Panel Form Validation",
      "description": "AI Generate panel form behavior: Generate button disabled when prompt is empty, enabled when prompt has content",
      "category": "form-validation",
      "assertions": [
        {
          "id": "wf-ai-generate-btn-disabled-empty",
          "description": "Generate button is disabled when prompt textarea is empty",
          "category": "form-validation",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Generate" },
            "label": "Generate button"
          },
          "assertionType": "disabled",
          "precondition": "AI panel is showing and prompt textarea is empty",
          "condition": {
            "type": "notExists",
            "target": {
              "type": "search",
              "criteria": { "role": "button", "textContent": "Run" }
            }
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-ai-textarea-enabled",
          "description": "Prompt textarea is enabled and accepts input",
          "category": "form-validation",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "textbox" },
            "label": "AI prompt textarea"
          },
          "assertionType": "enabled",
          "precondition": "AI panel is showing",
          "condition": {
            "type": "notExists",
            "target": {
              "type": "search",
              "criteria": { "role": "button", "textContent": "Run" }
            }
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
