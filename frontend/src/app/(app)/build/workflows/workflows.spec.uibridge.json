    {
      "id": "wf-page-purpose",
      "name": "Page Purpose",
      "description": "The Workflow Builder is the core authoring environment where users design, edit, and execute multi-phase AI automation workflows. Each workflow consists of four execution phases (setup, verification, agentic, completion) with individually configurable steps. Users can manage a library of workflows in the sidebar, run them directly from the editor, and export/import workflows as JSON.",
      "category": "semantic",
      "assertions": [
        {
          "id": "wf-purpose-manage",
          "description": "Users can create, search, duplicate, and delete workflows from the sidebar library",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Workflows" },
            "label": "Workflows sidebar heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-purpose-phases",
          "description": "Users can organize workflow steps into four execution phases: setup, verification, agentic, and completion",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Setup" },
            "label": "Setup phase section"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-purpose-run",
          "description": "Users can run workflows directly from the editor and monitor their execution status",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Run" },
            "label": "Run button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-purpose-ai-generate",
          "description": "Users can switch to AI generation mode to have workflows created automatically from a natural-language prompt",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Generate Workflow with AI" },
            "label": "AI generation panel"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "wf-purpose-export",
          "description": "Users can export workflows as JSON files and import previously saved workflows",
          "category": "semantic",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Export" },
            "label": "Export button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
