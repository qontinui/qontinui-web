{
  "version": "1.0.0",
  "description": "Inspector page — verifies page structure, SDK connection panel, inspector tabs, element discovery, and semantic page overview for inspecting connected applications",
  "groups": [
    {
      "id": "insp-page-structure",
      "name": "Page Structure",
      "description": "Verify the Inspector page renders its core layout elements",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-title",
          "description": "Page title 'Inspector' is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "heading",
              "textContent": "Inspector"
            },
            "label": "Page title"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-runner-status",
          "description": "Runner connection status badge is visible",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Runner Connected"
            },
            "label": "Runner status badge"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
