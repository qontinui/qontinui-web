    {
      "id": "insp-page-purpose",
      "name": "Page Purpose",
      "description": "The Inspector page allows developers to connect to any UI Bridge SDK-enabled application, discover its UI elements, inspect their properties, execute actions, view accessibility info, and discover page-level semantic specs. It serves as a universal debugging and testing tool for the qontinui platform.",
      "category": "semantic",
      "assertions": [
        {
          "id": "insp-purpose-connect",
          "description": "Users can connect to any application running the UI Bridge SDK by entering its URL",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Connected Apps"
            },
            "label": "Connection panel heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-purpose-discover",
          "description": "Users can discover all registered UI elements from the connected application",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "Discover Elements"
            },
            "label": "Discover Elements button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-purpose-inspect",
          "description": "Users can select any discovered element to view its full properties including type, bounds, visibility, and available actions",
          "category": "semantic",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Element Details"
            },
            "label": "Element details panel"
          },
          "assertionType": "exists",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": {
                "textContent": "elements found"
              },
              "label": "Element count indicator"
            },
            "text": "found"
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-purpose-specs",
          "description": "Users can discover page-level semantic specs that describe what each page of the connected application is supposed to achieve",
          "category": "semantic",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Page Specs"
            },
            "label": "Page Specs panel"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-element-details",
      "name": "Element Details",
      "description": "Verify the element detail panel displays correctly when elements are discovered",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-details-heading",
          "description": "Element Details heading is present",
          "category": "element-presence",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": {
              "role": "heading",
              "textContent": "Element Details"
            },
            "label": "Element Details heading"
          },
          "assertionType": "exists",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": {
                "textContent": "elements found"
              },
              "label": "Element count indicator"
            },
            "text": "found"
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-details-empty",
          "description": "Element detail panel shows 'Click on an element to view its details' when no element selected",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Click on an element to view its details"
            },
            "label": "Empty detail message"
          },
          "assertionType": "exists",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": {
                "textContent": "elements found"
              },
              "label": "Element count indicator"
            },
            "text": "found"
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-empty-states",
      "name": "Empty States",
      "description": "Verify empty state before element discovery",
      "category": "state-consistency",
      "assertions": [
        {
          "id": "insp-no-elements-empty",
          "description": "Shows 'No Elements Loaded' empty state before any elements are discovered",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "No Elements Loaded"
