{
  "version": "1.0.0",
  "description": "Specs for the unified Inspector page — verifies page structure, connection panel, inspector tabs, element discovery, and empty states",
  "groups": [
    {
      "id": "insp-page-structure",
      "name": "Page Structure",
      "description": "Verify the Inspector page renders its core layout elements",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-title",
          "description": "Page title 'Inspector' is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "heading",
              "textContent": "Inspector"
            },
            "label": "Page title"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-runner-status",
          "description": "Runner connection status badge is visible",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "textContent": "Runner Connected" },
            "label": "Runner status badge"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-connection-panel",
      "name": "Connection Panel",
      "description": "Verify both connection options are present",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-browser-tab-heading",
          "description": "Browser Tab connection card heading is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "heading", "textContent": "Browser Tab" },
            "label": "Browser Tab heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-desktop-app-heading",
          "description": "Desktop App connection card heading is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "heading", "textContent": "Desktop App" },
            "label": "Desktop App heading"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-refresh-tabs-button",
          "description": "Refresh Tabs button is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Refresh Tabs" },
            "label": "Refresh Tabs button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-discover-elements-button",
          "description": "Discover Elements button is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "Discover Elements"
            },
            "label": "Discover Elements button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-inspector-tabs",
      "name": "Inspector Tabs",
      "description": "Verify all six inspector tab buttons are present",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-elements-tab",
          "description": "Elements tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Elements" },
            "label": "Elements tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-actions-tab",
          "description": "Actions tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Actions" },
            "label": "Actions tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-accessibility-tab",
          "description": "Accessibility tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Accessibility" },
            "label": "Accessibility tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-search-tab",
          "description": "Search tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Search" },
            "label": "Search tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-specs-tab",
          "description": "Specs tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Specs" },
            "label": "Specs tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-api-tab",
          "description": "API tab button exists",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "API" },
            "label": "API tab"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-element-details",
      "name": "Element Details",
      "description": "Verify the element detail panel displays correctly",
      "category": "element-presence",
      "assertions": [
        {
          "id": "insp-details-heading",
          "description": "Element Details heading is present",
          "category": "element-presence",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "heading", "textContent": "Element Details" },
            "label": "Element Details heading"
          },
          "assertionType": "exists",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": { "textContent": "elements found" },
              "label": "Element count indicator"
            },
            "text": "found"
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-details-empty",
          "description": "Element detail panel shows 'Click on an element to view its details' when no element selected",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": {
              "textContent": "Click on an element to view its details"
            },
            "label": "Empty detail message"
          },
          "assertionType": "exists",
          "condition": {
            "type": "hasText",
            "target": {
              "type": "search",
              "criteria": { "textContent": "elements found" },
              "label": "Element count indicator"
            },
            "text": "found"
          },
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-empty-states",
      "name": "Empty States",
      "description": "Verify empty state before any connection",
      "category": "state-consistency",
      "assertions": [
        {
          "id": "insp-no-elements-empty",
          "description": "Shows 'No Elements Loaded' empty state before any connection",
          "category": "state-consistency",
          "severity": "info",
          "target": {
            "type": "search",
            "criteria": { "textContent": "No Elements Loaded" },
            "label": "No elements empty state"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
    {
      "id": "insp-accessibility",
      "name": "Accessibility",
      "description": "Verify ARIA and keyboard accessibility",
      "category": "accessibility",
      "assertions": [
        {
          "id": "insp-refresh-tabs-accessible",
          "description": "Refresh Tabs button is keyboard accessible",
          "category": "accessibility",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": { "role": "button", "textContent": "Refresh Tabs" },
            "label": "Refresh Tabs button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-discover-button-accessible",
          "description": "Discover Elements button is keyboard accessible",
          "category": "accessibility",
          "severity": "warning",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "Discover Elements"
            },
            "label": "Discover Elements button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    }
  ],
  "metadata": {
