            },
            "label": "Connect New App button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        },
        {
          "id": "insp-discover-elements-button",
          "description": "Discover Elements button is present",
          "category": "element-presence",
          "severity": "critical",
          "target": {
            "type": "search",
            "criteria": {
              "role": "button",
              "textContent": "Discover Elements"
            },
            "label": "Discover Elements button"
          },
          "assertionType": "exists",
          "source": "manual",
          "reviewed": true,
          "enabled": true
        }
      ],
      "source": "manual"
    },
