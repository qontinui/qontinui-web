{
  "version": "1.0",
  "id": "ai-tasks",
  "name": "AiTasks",
  "description": "The AI Tasks page for the qontinui-web app surfaces AI-assisted automation tasks scoped to the active project. When the user has no projects, the page renders a project-gated empty state instructing them to create their first project before AI Tasks become available. This spec covers that empty (no-project) state, which is what the captured snapshot shows. (Spec CI now seeds a fixture project on the ci-bot account, so with no project selected via URL this page renders the 'No project selected' gate rather than the 'No projects yet' first-project gate; assertions updated to the project-exists-but-unselected card.)",
  "provenance": {
    "source": "ai-generated",
    "appId": "qontinui-web"
  },
  "metadata": {
    "tags": [
      "ai-tasks",
      "empty-state"
    ]
  },
  "states": [
    {
      "id": "ai-tasks-empty-state",
      "name": "No projects empty state",
      "description": "Project-gated empty state shown when the workspace has zero projects. The AI Tasks feature is unavailable until a project exists.",
      "assertions": [
        {
          "id": "ai-tasks-empty-state-elem-0",
          "description": "Empty-state heading 'No projects yet' is rendered.",
          "category": "element-presence",
          "severity": "critical",
          "assertionType": "exists",
          "target": {
            "type": "search",
            "criteria": {
              "id": "heading-4-no-project-selected",
              "role": "heading"
            },
            "label": "No projects yet heading"
          },
