{
  "version": "1.0",
  "id": "workflow-viz",
  "name": "WorkflowViz",
  "description": "The Workflow Visualization page for the qontinui-web app renders workflow graphs scoped to the active project. When the user has no projects, the page renders a project-gated empty state instructing them to create their first project before Workflow Visualization becomes available. This spec covers that empty (no-project) state, which is what the captured snapshot shows.",
  "provenance": {
    "source": "ai-generated",
    "appId": "qontinui-web"
  },
  "metadata": {
    "tags": ["workflow-viz", "visualization", "empty-state"]
  },
  "states": [
    {
      "id": "workflow-viz-empty-state",
      "name": "No projects empty state",
      "description": "Project-gated empty state shown when the workspace has zero projects. Workflow Visualization is unavailable until a project exists.",
      "assertions": [
        {
          "id": "workflow-viz-empty-state-elem-0",
          "description": "Empty-state heading 'No projects yet' is rendered.",
          "category": "element-presence",
          "severity": "critical",
          "assertionType": "exists",
          "target": {
            "type": "search",
            "criteria": { "id": "heading-4-no-projects-yet", "role": "heading" },
            "label": "No projects yet heading"
          },
          "source": "ai-generated",
          "reviewed": false,
          "enabled": true
        },
        {
          "id": "workflow-viz-empty-state-elem-1",
          "description": "Explanatory paragraph ties the gate specifically to Workflow Visualization.",
          "category": "element-presence",
          "severity": "critical",
          "assertionType": "exists",
          "target": {
