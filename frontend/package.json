{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "next dev --port 3001 --hostname 0.0.0.0",
    "dev:fresh": "npm run clean && npm run dev",
    "clean": "npx rimraf .next node_modules/.cache",
    "build": "node scripts/inject-build-id.mjs pre && next build && node scripts/inject-build-id.mjs post",
    "start": "next start",
    "lint": "next lint --max-warnings 0",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "check:browser-safe-imports": "node scripts/check-browser-safe-imports.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "analyze": "node scripts/inject-build-id.mjs pre && npx cross-env ANALYZE=true next build && node scripts/inject-build-id.mjs post",
    "generate-api-types": "tsx scripts/generate-api-types.ts",
    "generate-api-types:local": "tsx scripts/generate-api-types.ts --local",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.9.1",
    "@monaco-editor/react": "^4.7.0",
    "@next/third-parties": "^15.5.12",
    "@qontinui/design-tokens": "^1.0.0",
    "@qontinui/shared-types": "^0.5.0",
    "@qontinui/ui-bridge": "^0.13.0",
    "@qontinui/ui-bridge-auto": "^0.1.7",
    "@qontinui/workflow-ui": "^0.1.0",
    "@qontinui/workflow-utils": "^0.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.3",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/dagre": "^0.7.53",
    "@types/dompurify": "^3.0.5",
    "@vercel/analytics": "^1.3.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.8.5",
    "axios": "^1.13.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.0",
    "framer-motion": "^12.23.25",
    "geist": "^1.3.1",
    "html2canvas": "^1.4.1",
    "immer": "^10.1.3",
    "ioredis": "^5.4.1",
    "jsdom": "^27.2.0",
    "lucide-react": "^0.562.0",
    "mermaid": "^11.12.1",
    "next": "^15.5.18",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "qontinui-navigation": "^0.1.0",
    "qrcode.react": "^4.2.0",
    "react": "19.1.5",
    "react-dom": "19.1.5",
    "react-hook-form": "^7.62.0",
    "react-markdown": "^10.1.0",
    "react-window": "^2.2.7",
    "recharts": "^3.2.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@next/bundle-analyzer": "^15.5.12",
    "@playwright/test": "^1.48.0",
    "@qontinui/ui-bridge-eslint-plugin": "^0.1.0",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.1.0",
    "ajv": "^8.20.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.9",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "openapi-typescript": "^7.10.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.3.8",
    "typescript": "^5",
    "vitest": "^4.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
