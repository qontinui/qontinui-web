{
  "AWSEBDockerrunVersion": 2,
  "volumes": [
    {
      "name": "redis-data",
      "host": {
        "sourcePath": "/var/app/redis-data"
      }
    },
    {
      "name": "uploads",
      "host": {
        "sourcePath": "/var/app/uploads"
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "redis",
      "image": "redis:7-alpine",
      "essential": true,
      "memory": 256,
      "command": [
        "redis-server",
        "--appendonly",
        "yes",
        "--maxmemory",
        "256mb",
        "--maxmemory-policy",
        "allkeys-lru"
      ],
      "mountPoints": [
        {
          "sourceVolume": "redis-data",
          "containerPath": "/data"
        }
      ]
    },
    {
      "name": "backend",
      "image": "backend",
      "essential": true,
      "memory": 384,
      "portMappings": [
        {
          "hostPort": 80,
          "containerPort": 8000
        }
      ],
      "links": [
        "redis"
      ],
      "environment": [
        {
          "name": "REDIS_HOST",
          "value": "redis"
        },
        {
          "name": "REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "REDIS_DB",
          "value": "0"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "uploads",
          "containerPath": "/app/uploads"
        }
      ]
    },
    {
      "name": "worker",
      "image": "backend",
      "essential": false,
      "memory": 256,
      "command": [
        "python",
        "run_worker.py"
      ],
      "links": [
        "redis"
      ],
      "environment": [
        {
          "name": "REDIS_HOST",
          "value": "redis"
        },
        {
          "name": "REDIS_PORT",
          "value": "6379"
        },
        {
          "name": "REDIS_DB",
          "value": "0"
        }
      ]
    }
  ]
}
