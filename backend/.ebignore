# Ignore Docker files (not needed for Python platform)
Dockerfile
Dockerrun.aws.json
docker-compose.yml
docker-compose*.yml
.dockerignore

# Ignore local development files
.env
.env.local
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Ignore documentation and non-deployment files
docs/
*.md
!README.md

# Ignore test files
tests/
pytest.ini

# Ignore Git files
.git/
.gitignore

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore logs
*.log
logs/

# Ignore entire .elasticbeanstalk directory (except config.yml which is needed)
.elasticbeanstalk/logs/
.elasticbeanstalk/app_versions/

# Ignore terraform (not needed for deployment)
terraform/

# Ignore development/test artifacts
htmlcov/
coverage.xml
.coverage
.mypy_cache/

# Ignore user projects directory (local development only)
user_projects/

# Ignore ML/dataset files (not needed for web backend)
ml/
dataset*.py
backup_migrations/
