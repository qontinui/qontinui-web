# Database - PostgreSQL only (same for development and production)
DATABASE_URL=postgresql://qontinui_user:qontinui_dev_password@localhost:5432/qontinui_db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
REMEMBER_ME_TOKEN_EXPIRE_DAYS=90

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True
DEBUG=True

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Runner (Desktop App) Configuration
# WebSocket URL that runners use to stream automation data
# For WSL development, use the WSL IP address (e.g., ws://172.x.x.x:8001)
# To find WSL IP: run `ip addr show eth0` in WSL and look for inet
RUNNER_WS_URL=ws://localhost:8001

# Backend HTTP URL that runners use for REST API calls
# For WSL development, use the WSL IP address (e.g., http://172.x.x.x:8000)
# For production, set to your public backend URL (e.g., https://api.qontinui.io)
RUNNER_BACKEND_URL=http://localhost:8000

# Email Configuration (Optional - emails won't send if not configured)
# Email verification is enabled and will send verification emails on registration
# Password reset emails and beta welcome emails also use this configuration
#
# For Gmail:
#   - SMTP_HOST=smtp.gmail.com
#   - SMTP_PORT=587
#   - Use App Password (https://support.google.com/accounts/answer/185833)
#   - SMTP_USER=your-email@gmail.com
#   - SMTP_PASSWORD=your-app-password
#
# For SendGrid:
#   - SMTP_HOST=smtp.sendgrid.net
#   - SMTP_PORT=587
#   - SMTP_USER=apikey
#   - SMTP_PASSWORD=your-sendgrid-api-key
#
# For AWS SES:
#   - SMTP_HOST=email-smtp.us-east-1.amazonaws.com (replace region)
#   - SMTP_PORT=587
#   - SMTP_USER=your-ses-smtp-user
#   - SMTP_PASSWORD=your-ses-smtp-password
#
# For local testing: Use MailHog (https://github.com/mailhog/MailHog)
#   - SMTP_HOST=localhost
#   - SMTP_PORT=1025
#   - SMTP_TLS=false
#   - Leave SMTP_USER and SMTP_PASSWORD empty
#
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@qontinui.com

# Redis (for task queue and caching) - Optional
# Set REDIS_ENABLED=false to disable Redis (emails will be sent synchronously)
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Stripe (Optional - for billing features)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_HOBBY=price_...
STRIPE_PRICE_PRO=price_...

# Object Storage Configuration
# Options: local (default), minio (development), s3 (production)
STORAGE_BACKEND=local

# MinIO Configuration (for development)
# Uncomment these when using MinIO with docker-compose
# STORAGE_BACKEND=minio
# STORAGE_BUCKET_NAME=qontinui
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin
# STORAGE_ENDPOINT_URL=http://localhost:9000
# STORAGE_USE_SSL=false

# AWS S3 Configuration (for production)
# Uncomment these when deploying to production with S3
# STORAGE_BACKEND=s3
# STORAGE_BUCKET_NAME=qontinui-production
# STORAGE_REGION=us-east-1
# STORAGE_ACCESS_KEY=your-aws-access-key
# STORAGE_SECRET_KEY=your-aws-secret-key
# STORAGE_USE_SSL=true

# CloudFront CDN Configuration (optional, for production)
# Improves image delivery performance with edge caching
# Run `python scripts/setup_cloudfront.py --bucket your-bucket-name` to create distribution
# USE_CLOUDFRONT=true
# CLOUDFRONT_DOMAIN=d123abc.cloudfront.net
# CLOUDFRONT_DISTRIBUTION_ID=E123ABC456DEF

# Database Query Timing Configuration
# See app/middleware/DATABASE_TIMING_README.md for detailed documentation
#
# Enable database query logging and statistics
# IMPORTANT: Set to false in production for performance (default: false)
ENABLE_QUERY_LOGGING=false

# Threshold in milliseconds for logging slow queries
# Queries slower than this will be logged even when ENABLE_QUERY_LOGGING=false
# Recommended: 100ms (development), 200ms (production)
SLOW_QUERY_THRESHOLD_MS=100

# Maximum number of queries per request before warning
# Helps detect N+1 query problems
# Recommended: 20 (development), 50 (production)
MAX_QUERIES_PER_REQUEST=20
