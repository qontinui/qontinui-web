# Database
DATABASE_URL=postgresql://qontinui_user:your_password@localhost:5432/qontinui_db

# For SQLite (development)
# DATABASE_URL=sqlite:///./qontinui.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True
DEBUG=True

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional - emails won't send if not configured)
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use App Password
# For SendGrid: SMTP_HOST=smtp.sendgrid.net, SMTP_PORT=587
# For local testing: Use MailHog or similar
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@qontinui.com
