# Database
DATABASE_URL=postgresql://qontinui_user:your_password@localhost:5432/qontinui_db

# For SQLite (development)
# DATABASE_URL=sqlite:///./qontinui.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=True
DEBUG=True

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Email Configuration (Optional - emails won't send if not configured)
# Email verification is enabled and will send verification emails on registration
# Password reset emails and beta welcome emails also use this configuration
#
# For Gmail:
#   - SMTP_HOST=smtp.gmail.com
#   - SMTP_PORT=587
#   - Use App Password (https://support.google.com/accounts/answer/185833)
#   - SMTP_USER=your-email@gmail.com
#   - SMTP_PASSWORD=your-app-password
#
# For SendGrid:
#   - SMTP_HOST=smtp.sendgrid.net
#   - SMTP_PORT=587
#   - SMTP_USER=apikey
#   - SMTP_PASSWORD=your-sendgrid-api-key
#
# For AWS SES:
#   - SMTP_HOST=email-smtp.us-east-1.amazonaws.com (replace region)
#   - SMTP_PORT=587
#   - SMTP_USER=your-ses-smtp-user
#   - SMTP_PASSWORD=your-ses-smtp-password
#
# For local testing: Use MailHog (https://github.com/mailhog/MailHog)
#   - SMTP_HOST=localhost
#   - SMTP_PORT=1025
#   - SMTP_TLS=false
#   - Leave SMTP_USER and SMTP_PASSWORD empty
#
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@qontinui.com
