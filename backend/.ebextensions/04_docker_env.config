container_commands:
  01_create_env_file:
    command: |
      # Create .env file for docker-compose from EB environment variables
      echo "Creating .env file for docker-compose..."
      /opt/elasticbeanstalk/bin/get-config environment | jq -r 'to_entries | .[] | "\(.key)=\(.value)"' > /var/app/staging/.env
      echo ".env file created at /var/app/staging/.env"
      echo "Contents:"
      cat /var/app/staging/.env
