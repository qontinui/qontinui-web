files:
  "/opt/elasticbeanstalk/hooks/appdeploy/pre/00_create_env_file.sh":
    mode: "000755"
    owner: root
    group: root
    content: |
      #!/bin/bash
      # Create .env file for docker-compose from EB environment variables
      ENV_FILE=/var/app/current/.env

      echo "Creating .env file for docker-compose..."

      # Get environment variables from EB and write to .env file
      /opt/elasticbeanstalk/bin/get-config environment | jq -r 'to_entries | .[] | "\(.key)=\(.value)"' > $ENV_FILE

      echo ".env file created with $(wc -l < $ENV_FILE) variables"
      cat $ENV_FILE
