###############################################################################
# CloudWatch Logs Configuration (Simplified)
#
# Uses only EB's built-in log streaming - no custom resources
###############################################################################

option_settings:
  # Enable log streaming (EB handles everything)
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7

  # Enable health streaming
  aws:elasticbeanstalk:cloudwatch:logs:health:
    HealthStreamingEnabled: true
    DeleteOnTerminate: false
    RetentionInDays: 7
