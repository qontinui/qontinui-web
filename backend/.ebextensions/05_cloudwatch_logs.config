###############################################################################
# CloudWatch Logs Configuration
#
# Configures log streaming to CloudWatch Logs for centralized logging
# - Application logs (JSON structured)
# - Nginx access logs
# - Nginx error logs
# - System logs
# All logs retained for 7 days (cost optimization)
###############################################################################

option_settings:
  # Enable log streaming
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: true
    DeleteOnTerminate: false
    RetentionInDays: 7  # 7-day retention for cost savings

  # Enable health streaming
  aws:elasticbeanstalk:cloudwatch:logs:health:
    HealthStreamingEnabled: true
    DeleteOnTerminate: false
    RetentionInDays: 7

Resources:
  # Application Log Group
  ApplicationLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/elasticbeanstalk/qontinui-prod/application
      RetentionInDays: 7

  # Nginx Access Log Group
  NginxAccessLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/elasticbeanstalk/qontinui-prod/nginx-access
      RetentionInDays: 7

  # Nginx Error Log Group
  NginxErrorLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/elasticbeanstalk/qontinui-prod/nginx-error
      RetentionInDays: 7

  # System Log Group
  SystemLogGroup:
    Type: AWS::Logs::LogGroup
    Properties:
      LogGroupName: /aws/elasticbeanstalk/qontinui-prod/system
      RetentionInDays: 7

files:
  # CloudWatch Logs Agent configuration
  "/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json":
    mode: "000644"
    owner: root
    group: root
    content: |
      {
        "logs": {
          "logs_collected": {
            "files": {
              "collect_list": [
                {
                  "file_path": "/var/log/eb-docker/containers/eb-current-app/*.log",
                  "log_group_name": "/aws/elasticbeanstalk/qontinui-prod/application",
                  "log_stream_name": "{instance_id}",
                  "timezone": "UTC"
                },
                {
                  "file_path": "/var/log/nginx/access.log",
                  "log_group_name": "/aws/elasticbeanstalk/qontinui-prod/nginx-access",
                  "log_stream_name": "{instance_id}",
                  "timezone": "UTC"
                },
                {
                  "file_path": "/var/log/nginx/error.log",
                  "log_group_name": "/aws/elasticbeanstalk/qontinui-prod/nginx-error",
                  "log_stream_name": "{instance_id}",
                  "timezone": "UTC"
                },
                {
                  "file_path": "/var/log/eb-engine.log",
                  "log_group_name": "/aws/elasticbeanstalk/qontinui-prod/system",
                  "log_stream_name": "{instance_id}-eb-engine",
                  "timezone": "UTC"
                }
              ]
            }
          }
        }
      }
